# OpenAI API Key (erforderlich)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Remove.bg API Key (optional, fuer Hintergrund-Cleanup)
# https://www.remove.bg/api
REMOVEBG_API_KEY=

# Bildgroesse fuer DALL-E (1024x1024 empfohlen)
IMAGE_SIZE=1024x1024

# Modell (dall-e-3 empfohlen)
IMAGE_MODEL=dall-e-3

# Qualitaet (standard oder hd)
IMAGE_QUALITY=hd
